VALUES

-- ── MANHATTAN ────────────────────────────────────────────────
(1,  4, 'One57 Sky Suite',
 'one57-sky-suite',
 'Perched on the 58th floor of Billionaires'' Row, this breathtaking penthouse suite offers unobstructed Central Park panoramas. Floor-to-ceiling windows flood every room with natural light. The chef''s kitchen features Miele appliances, while the master suite includes a spa bath with heated marble floors. White-glove concierge service available around the clock.',
 'penthouse', 'for_sale', 14950000, 4800, 5, 5, 58, 2014,
 '157 West 57th Street, Apt 58A', 'New York City', 'New York', '10019', 'US',
 1, 1, '2018-03-15 10:00:00', '2024-12-20 14:30:00'),

(2,  1, 'St. George Bayfront Residence',
 'st-george-bayfront-residence',
 'This spacious three-bedroom apartment sits in the heart of Washington Heights with breathtaking Hudson River views. Renovated open-plan living areas showcase wide-plank hardwood floors and custom millwork throughout. The gourmet kitchen includes quartz countertops and stainless steel appliances. Building amenities include a landscaped rooftop terrace and state-of-the-art fitness center.',
 'apartment', 'for_rent', 4000, 2660, 3, 2, 12, 2008,
 '45 Cabrini Boulevard, Apt 12C', 'New York City', 'New York', '10033', 'US',
 1, 1, '2019-05-20 09:15:00', '2025-01-10 11:20:00'),

(3,  4, 'SoHo Cast Iron Loft',
 'soho-cast-iron-loft',
 'Authentic SoHo loft occupying an entire floor of a landmark cast-iron building. Original exposed brick walls and massive industrial windows celebrate the neighborhood''s artistic heritage. Twelve-foot ceilings create gallery-worthy proportions throughout the open plan space. The custom kitchen and live-edge walnut island make this a true entertainer''s paradise in downtown Manhattan.',
 'apartment', 'for_rent', 5200, 3660, 4, 3, 6, 1895,
 '110 Prince Street, Loft 4', 'New York City', 'New York', '10012', 'US',
 1, 1, '2020-08-12 16:45:00', '2025-02-14 10:00:00'),

(4,  1, 'Tribeca Terrace Residence',
 'tribeca-terrace-residence',
 'Elegant three-bedroom apartment in a full-service Tribeca condominium steps from Hudson River Park. Generous proportions and south-facing exposure ensure natural light throughout the day. The principal bedroom features a walk-in closet and marble en-suite bath. Building offers 24-hour doorman, children''s playroom, and a beautifully landscaped private residents'' garden.',
 'apartment', 'for_rent', 3200, 2310, 3, 2, 9, 2003,
 '200 Chambers Street, Apt 9D', 'New York City', 'New York', '10007', 'US',
 0, 1, '2021-01-25 08:30:00', '2025-03-18 15:45:00'),

(5,  4, 'Chelsea Garden Penthouse',
 'chelsea-garden-penthouse',
 'Sprawling full-floor penthouse crowning a boutique Chelsea building, complete with a wraparound private terrace and open-sky Manhattan views. The double-height living room is anchored by a gas fireplace and bespoke bookshelves. A separate guest wing ensures complete privacy. World-class galleries, the High Line, and Chelsea Market are all within a two-block radius.',
 'penthouse', 'for_sale', 7500000, 3200, 4, 3, 10, 2001,
 '215 West 23rd Street, PH', 'New York City', 'New York', '10011', 'US',
 1, 1, '2018-11-08 13:20:00', '2024-09-22 09:10:00'),

(6,  1, 'West Side Towers Residence',
 'west-side-towers-residence',
 'Rare six-bedroom, four-bath apartment on the Upper West Side combining two adjacent units into a single grand home. The result is over 5,100 square feet of refined living space with dual chef''s kitchens, formal dining, and a private library. Enjoy iconic Hudson River sunsets from every west-facing room. Full-service building with pool and attended parking garage.',
 'apartment', 'for_sale', 9800000, 5100, 6, 4, 22, 1997,
 '392 Central Park West, Apt 22AB', 'New York City', 'New York', '10025', 'US',
 0, 1, '2019-07-14 11:00:00', '2025-01-05 14:30:00'),

(7,  4, 'Battery Park Vista',
 'battery-park-vista',
 'Luminous three-bedroom corner unit in a premier Battery Park City tower with Statue of Liberty and New York Harbor views. Floor-to-ceiling glass walls make the harbor a living artwork. The residence features wide-plank oak floors, motorized shades, and integrated smart-home technology. Residents enjoy a resort-style rooftop pool and private marina access just steps away.',
 'apartment', 'sold', 4600, 2800, 3, 2, 30, 2010,
 '300 Vesey Street, Apt 30F', 'New York City', 'New York', '10282', 'US',
 0, 1, '2020-02-28 10:15:00', '2024-11-30 16:00:00'),

(8,  1, 'Midtown Skyline Studio',
 'midtown-skyline-studio',
 'Thoughtfully designed studio with stunning Midtown skyline views from the 27th floor. High-end finishes include Italian marble countertops, integrated appliances, and motorized blackout blinds. The Murphy bed system with built-in shelving maximizes every square inch. Residents enjoy a full suite of amenities including a rooftop deck overlooking the Empire State Building.',
 'studio', 'for_rent', 3800, 650, 0, 1, 27, 2018,
 '333 East 45th Street, Apt 27B', 'New York City', 'New York', '10017', 'US',
 0, 1, '2021-06-10 09:45:00', '2025-04-12 11:20:00'),

(9,  4, 'Gramercy Park Classic',
 'gramercy-park-classic',
 'Coveted prewar six-room apartment overlooking the private Gramercy Park. Original architectural details — coffered ceilings, herringbone parquet floors, and decorative fireplaces — have been lovingly preserved and updated with modern systems. The private key to Gramercy Park is an incomparable lifestyle privilege in one of Manhattan''s most sought-after and historic neighborhoods.',
 'apartment', 'for_sale', 3695000, 2400, 3, 2, 7, 1927,
 '34 Gramercy Park East, Apt 7A', 'New York City', 'New York', '10003', 'US',
 0, 1, '2018-09-19 15:30:00', '2024-12-08 10:45:00'),

(10, 1, 'Financial District Corner Suite',
 'financial-district-corner-suite',
 'Dramatic corner two-bedroom with panoramic views spanning the Brooklyn Bridge, East River, and lower Manhattan skyline. Converted from a historic office tower, the unit retains original terrazzo floors and oversized industrial windows. The open kitchen features custom cabinetry and a wine refrigerator. A short walk to Wall Street, Fulton Center, and the Oculus transportation hub.',
 'apartment', 'for_rent', 2950, 1420, 2, 2, 18, 1932,
 '99 John Street, Apt 18C', 'New York City', 'New York', '10038', 'US',
 0, 1, '2019-12-05 14:00:00', '2025-02-20 09:30:00'),

-- ── BROOKLYN ─────────────────────────────────────────────────
(11, 2, 'Park Slope Brownstone',
 'park-slope-brownstone',
 'Meticulously restored three-story brownstone on one of Park Slope''s most coveted tree-lined blocks. The owner''s triplex features original pocket doors, two decorative fireplaces, and a stunning parlor floor with fourteen-foot ceilings. A private backyard garden offers a serene urban retreat. Steps from Prospect Park, the Brooklyn Museum, and exceptional local dining.',
 'villa', 'for_sale', 4695000, 4200, 5, 3, 3, 1899,
 '253 8th Avenue', 'Brooklyn', 'New York', '11215', 'US',
 1, 1, '2018-04-22 12:00:00', '2024-10-15 13:45:00'),

(12, 2, 'DUMBO Waterfront Loft',
 'dumbo-waterfront-loft',
 'Spectacular converted factory loft in DUMBO with jaw-dropping Manhattan Bridge and skyline views. Soaring sixteen-foot ceilings, exposed steel columns, and original maple floors set the stage for dramatic urban living. The custom kitchen anchors the vast open-plan layout. A private deeded parking space and storage unit complete this rare offering in Brooklyn''s most iconic waterfront neighborhood.',
 'apartment', 'for_sale', 2895000, 2100, 2, 2, 4, 1912,
 '30 Main Street, Unit 4E', 'Brooklyn', 'New York', '11201', 'US',
 1, 1, '2020-03-18 10:30:00', '2024-11-28 15:15:00'),

(13, 2, 'Heights Residence Townhouse',
 'heights-residence-townhouse',
 'Grand five-bedroom townhouse in Brooklyn Heights with sweeping New York Harbor and Lower Manhattan views from the rooftop deck. The renovated four-story home features a chef''s kitchen, formal dining room, and a finished garden-level suite. Every bedroom has generous closet space. Brooklyn Heights Promenade, the Brooklyn Bridge, and excellent public transit are all nearby.',
 'villa', 'for_rent', 6000, 4408, 5, 3, 4, 1910,
 '75 Pierrepont Street', 'Brooklyn', 'New York', '11201', 'US',
 1, 1, '2019-08-30 11:15:00', '2025-01-22 14:00:00'),

(14, 2, 'South Bronx Creative Flat',
 'south-bronx-creative-flat',
 'Bright and airy two-bedroom apartment in a newly converted warehouse building in Mott Haven. The industrial aesthetic is softened by warm oak flooring and custom kitchen cabinetry. Large factory windows flood the space with natural light throughout the day. The building features an artist''s co-working studio, rooftop terrace with Manhattan views, and secure bicycle storage.',
 'apartment', 'for_rent', 2100, 1420, 2, 1, 3, 2020,
 '375 Third Avenue', 'Bronx', 'New York', '10454', 'US',
 0, 1, '2021-09-12 08:45:00', '2025-03-05 10:20:00'),

(15, 3, 'Williamsburg Penthouse',
 'williamsburg-penthouse',
 'Stunning full-floor penthouse in a boutique Williamsburg development with private rooftop terrace and wraparound Manhattan skyline views. The open-plan interior is finished with white oak floors, Calacatta marble, and Gaggenau appliances. A private elevator opens directly into the residence. The vibrant neighborhood offers world-class dining, nightlife, and the L-train steps from the front door.',
 'penthouse', 'for_sale', 3895000, 2900, 3, 3, 8, 2022,
 '185 North 7th Street, PH', 'Brooklyn', 'New York', '11211', 'US',
 1, 1, '2022-05-20 09:00:00', '2024-12-18 11:30:00'),

(16, 2, 'Cobble Hill Garden Duplex',
 'cobble-hill-garden-duplex',
 'Charming garden-level duplex in a classic Cobble Hill brownstone with a private south-facing garden and original prewar details. The upper floor hosts two bedrooms and a renovated bath, while the garden level offers a spacious family room opening to the terrace. Cobble Hill Park, artisan cafes, the F and G trains, and the Brooklyn Queens Expressway are all close by.',
 'apartment', 'for_rent', 2800, 1680, 2, 2, 2, 1905,
 '126 Clinton Street, Apt GD', 'Brooklyn', 'New York', '11201', 'US',
 0, 1, '2020-10-08 13:00:00', '2025-02-11 09:45:00'),

(17, 2, 'Bed-Stuy Classic Brownstone',
 'bed-stuy-classic-brownstone',
 'Beautifully renovated four-story brownstone on a landmark-designated block in Bedford-Stuyvesant. The owner''s duplex retains original stained-glass windows, ornate plasterwork, and two working fireplaces. The chef''s kitchen and formal dining room are ideal for entertaining. Two rental income units on the lower floors provide strong cash flow in this rapidly appreciating Brooklyn neighborhood.',
 'villa', 'for_sale', 2499000, 3800, 4, 3, 4, 1895,
 '483 Decatur Street', 'Brooklyn', 'New York', '11233', 'US',
 0, 1, '2019-11-15 10:30:00', '2024-09-25 14:15:00'),

(18, 3, 'Greenpoint Waterfront Studio',
 'greenpoint-waterfront-studio',
 'Modern studio in a newly built Greenpoint tower with East River and Manhattan skyline views. The compact but intelligent layout features a built-in Murphy bed, Italian kitchen with induction cooktop, and custom storage throughout. Floor-to-ceiling windows maximize the dramatic views. The building includes a co-working lounge, yoga studio, rooftop pool, and full-time concierge service.',
 'studio', 'for_rent', 2150, 580, 0, 1, 14, 2023,
 '21 India Street, Unit 14A', 'Brooklyn', 'New York', '11222', 'US',
 0, 1, '2023-07-01 12:00:00', '2025-04-08 10:00:00'),

-- ── QUEENS ───────────────────────────────────────────────────
(19, 3, 'Long Island City Skyline Tower',
 'long-island-city-skyline-tower',
 'Sleek two-bedroom apartment in a newly delivered LIC high-rise with unobstructed Midtown Manhattan views from the 24th floor. Open-plan living and dining is anchored by a waterfall-edge island and integrated Sub-Zero and Wolf appliances. Spa-like bathrooms feature radiant-heated floors. The building''s amenity deck includes an Olympic-length pool, indoor basketball court, and sky lounge.',
 'apartment', 'for_rent', 3400, 1380, 2, 2, 24, 2021,
 '41-42 24th Street, Apt 24F', 'Queens', 'New York', '11101', 'US',
 1, 1, '2021-10-12 11:30:00', '2025-01-15 13:20:00'),

(20, 3, 'Astoria Garden Townhouse',
 'astoria-garden-townhouse',
 'Spacious three-bedroom townhouse in a quiet Astoria residential block with a private rear garden and attached garage. The renovated kitchen opens to a sunny family room with direct garden access, perfect for outdoor dining in warmer months. The full basement provides abundant storage. Astoria Park, museums, excellent Greek dining, and the N and W subway lines are all minutes away.',
 'townhouse', 'for_sale', 1899000, 2200, 3, 2, 3, 1958,
 '27-15 Shore Boulevard', 'Queens', 'New York', '11102', 'US',
 0, 1, '2018-12-20 09:15:00', '2024-10-30 15:00:00'),

(21, 3, 'Flushing Modern Apartment',
 'flushing-modern-apartment',
 'Contemporary two-bedroom apartment in the heart of Flushing, one block from the 7 train and Flushing Meadows-Corona Park. The open kitchen features quartz countertops and stainless appliances. Both bedrooms are generously sized with ample closet space. The building offers a modern lobby, gym, rooftop terrace, and video intercom security in a vibrant multicultural neighborhood.',
 'apartment', 'for_rent', 1850, 980, 2, 1, 6, 2019,
 '136-20 Roosevelt Avenue, Apt 6B', 'Queens', 'New York', '11354', 'US',
 0, 1, '2020-06-25 14:45:00', '2025-03-12 11:00:00'),

(22, 3, 'Jamaica Hills Colonial Home',
 'jamaica-hills-colonial-home',
 'Handsome four-bedroom Colonial home with a covered front porch, two-car garage, and a deep private backyard on a quiet cul-de-sac. The interior features hardwood floors throughout, a formal living room with fireplace, and an updated eat-in kitchen. Proximity to JFK International Airport and Jamaica Station makes this a superb choice for professionals with frequent travel needs.',
 'villa', 'for_sale', 979000, 2650, 4, 2, 2, 1955,
 '170-25 Depot Road', 'Queens', 'New York', '11432', 'US',
 0, 1, '2019-02-14 10:00:00', '2024-11-05 12:30:00'),

(23, 3, 'Bayside Waterfront Villa',
 'bayside-waterfront-villa',
 'Exceptional five-bedroom waterfront villa on Little Neck Bay with a private dock and sweeping water views. The chef''s kitchen opens to a great room with stone fireplace and direct access to a landscaped terrace. The master suite occupies the entire upper floor with a private balcony overlooking the bay. An attached two-car garage and generator provide year-round comfort and convenience.',
 'villa', 'for_sale', 3899000, 4600, 5, 4, 2, 1988,
 '39-12 222nd Street', 'Queens', 'New York', '11361', 'US',
 1, 1, '2018-07-08 13:45:00', '2024-09-18 10:15:00'),

-- ── BRONX ────────────────────────────────────────────────────
(24, 1, 'Riverdale Manor Estate',
 'riverdale-manor-estate',
 'Magnificent six-bedroom Tudor manor set on a half-acre landscaped lot in the prestigious Riverdale enclave. The stately residence features a grand entry hall, library with custom built-ins, and a formal dining room with original coffered ceilings. The resort-style backyard includes a pool, pergola, and mature specimen trees. Private school, riverfront parkland, and express buses to Midtown nearby.',
 'villa', 'for_sale', 5490000, 6200, 6, 5, 3, 1938,
 '4900 Independence Avenue', 'Bronx', 'New York', '10471', 'US',
 1, 1, '2018-05-30 11:20:00', '2024-12-02 14:45:00'),

(25, 1, 'Fordham Heights Studio',
 'fordham-heights-studio',
 'Newly renovated studio apartment in a well-maintained pre-war elevator building steps from Fordham University and the D and B subway lines. The efficient layout features a modern kitchen with subway-tile backsplash, a tiled bath, and ample closet space. Ideal for a student, young professional, or investor seeking a low-maintenance income property in a highly connected Bronx neighborhood.',
 'studio', 'for_rent', 1290, 540, 0, 1, 5, 1952,
 '2459 Jerome Avenue, Apt 5C', 'Bronx', 'New York', '10468', 'US',
 0, 1, '2021-04-18 09:00:00', '2025-02-28 10:30:00'),

-- ── NEW JERSEY ───────────────────────────────────────────────
(26, 2, 'Hoboken Brownstone',
 'hoboken-brownstone',
 'Stunning four-story brownstone in uptown Hoboken with a private roof deck and jaw-dropping Manhattan skyline views. The residence spans four levels, offering flexible living and home-office arrangements. The chef''s kitchen opens to a parlor floor with original fireplace and wide-plank floors. A private garage for two cars, a rarity in Hoboken, rounds out this truly exceptional urban home.',
 'villa', 'for_sale', 2295000, 3200, 4, 3, 4, 1891,
 '1027 Hudson Street', 'Hoboken', 'New Jersey', '07030', 'US',
 0, 1, '2019-09-10 12:15:00', '2024-10-22 11:45:00'),

(27, 2, 'Jersey City Grove Street Condo',
 'jersey-city-grove-street-condo',
 'Pristine two-bedroom, two-bath condominium in Jersey City''s highly desirable Grove Street Path district. The sleek open-plan kitchen with waterfall island is perfect for entertaining. Both bedrooms offer generous closet space, and the master features a marble en-suite bath. Direct PATH train access puts Midtown Manhattan less than fifteen minutes away. In-unit washer-dryer and parking included.',
 'apartment', 'for_rent', 2900, 1190, 2, 2, 11, 2016,
 '65 Christopher Columbus Drive, Apt 11D', 'Jersey City', 'New Jersey', '07302', 'US',
 0, 1, '2020-11-05 10:45:00', '2025-03-20 09:00:00'),

-- ── CONNECTICUT ──────────────────────────────────────────────
(28, 4, 'Greenwich Estate',
 'greenwich-estate',
 'Grand seven-bedroom Georgian estate on six manicured acres in one of Greenwich''s finest back-country neighborhoods. The twenty-two-room mansion features a two-story library, wine cellar, home theater, and a guest cottage. The grounds include a regulation tennis court, heated pool, and a carriage house with three-car garage. Top-ranked Greenwich schools and a thirty-minute train to Grand Central Station.',
 'villa', 'for_sale', 12950000, 9800, 7, 8, 3, 1964,
 '47 Round Hill Road', 'Greenwich', 'Connecticut', '06831', 'US',
 1, 1, '2018-01-25 14:30:00', '2024-11-12 13:00:00'),

(29, 4, 'Westport Colonial Home',
 'westport-colonial-home',
 'Beautifully renovated five-bedroom Colonial in one of Westport''s most sought-after beach neighborhoods. The sun-drenched kitchen and family room open to a wraparound deck overlooking the pool and spa. Four-car garage plus a charming one-bedroom guest cottage. Short walk to Compo Beach on Long Island Sound. New Canaan Amtrak station and top-rated Westport public schools are convenient nearby.',
 'villa', 'for_sale', 4499000, 5400, 5, 5, 2, 2002,
 '15 Beachside Avenue', 'Westport', 'Connecticut', '06880', 'US',
 0, 1, '2019-03-17 11:00:00', '2024-12-28 15:30:00'),

-- ── FLORIDA ──────────────────────────────────────────────────
(30, 4, 'Miami Beach Ocean Drive Penthouse',
 'miami-beach-ocean-drive-penthouse',
